---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import ThermalCalculator from '../components/react/ThermalCalculator.jsx';
import img1 from '../img/modelo_1.png';
import img2 from '../img/modelo_2.png';
import img3 from '../img/modelo_3.png';
import Footer from '../components/Footer.astro';
---

<Layout>
	<Header />
	
	<main>
		<Hero />
		<Features />
		<ThermalCalculator client:visible />
		
		<!-- Seccion de Modelos (Static Placeholder)	 -->
		<section id="modelos" class="py-20 bg-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-4xl font-bold text-black-primary mb-4">Colección de viviendas</h2>
					<p class="text-lg text-slate-technical max-w-2xl mx-auto">
						Descubre nuestras estructuras modulares y residencias pre-fabricadas con el sistema SIP de VERTYS.
					</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<!-- Card 1 -->
					<div class="bg-grey-light rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col h-full border border-gray-50">
						<div class="h-64 overflow-hidden">
							<img src={img1.src} alt="Modelo 1" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
						</div>
						<div class="p-6 flex-grow flex flex-col">
							<h3 class="text-xl font-bold text-text-dark mb-2">Modelo 1 - 24 m2</h3>
							<p class="text-slate-technical text-sm mb-4">1 dormitorio, 1 piso. Estructura compacta y eficiente.</p>
							<div class="mt-auto pt-4 border-t border-gray-100">
								<a href="/catalogo" class="text-gold-accent font-bold hover:text-yellow-600 transition-colors inline-flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
								</a>
							</div>
						</div>
					</div>
					
					<!-- Card 2 -->
					<div class="bg-grey-light rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col h-full border border-gray-50">
						<div class="h-64 overflow-hidden">
							<img src={img2.src} alt="Modelo 2" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
						</div>
						<div class="p-6 flex-grow flex flex-col">
							<h3 class="text-xl font-bold text-text-dark mb-2">Modelo 2 - 48 m2</h3>
							<p class="text-slate-technical text-sm mb-4">2 dormitorios, 1 piso. Espacio familiar optimizado.</p>
							<div class="mt-auto pt-4 border-t border-gray-100">
								<a href="/catalogo" class="text-gold-accent font-bold hover:text-yellow-600 transition-colors inline-flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
								</a>
							</div>
						</div>
					</div>
					
					<!-- Card 3 -->
					<div class="bg-grey-light rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col h-full border border-gray-50">
						<div class="h-64 overflow-hidden">
							<img src={img3.src} alt="Modelo 3" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
						</div>
						<div class="p-6 flex-grow flex flex-col">
							<h3 class="text-xl font-bold text-text-dark mb-2">Modelo 3 - 70 m2</h3>
							<p class="text-slate-technical text-sm mb-4">3 dormitorios, 1 piso. Amplios ambientes interiores.</p>
							<div class="mt-auto pt-4 border-t border-gray-100">
								<a href="/catalogo" class="text-gold-accent font-bold hover:text-yellow-600 transition-colors inline-flex items-center">
									Ver detalles
									<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
								</a>
							</div>
						</div>
					</div>
				</div>
				
				<div class="mt-12 text-center">
					<a href="/catalogo" class="inline-flex items-center justify-center px-8 py-3 border border-black-primary text-base font-medium rounded-full text-black-primary hover:bg-black-primary hover:text-white transition-colors">
						Ver catálogo completo
					</a>
				</div>
			</div>
		</section>

		<!-- Sección de Contacto -->
		<section id="contacto" class="py-24 bg-grey-light">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col lg:flex-row gap-16">
					
					<!-- Información de Contacto -->
					<div class="w-full lg:w-5/12">
						<div class="inline-block px-4 py-1 rounded-full bg-white border border-gray-200 text-gold-accent font-bold text-sm mb-6 tracking-widest uppercase">
							Contacto
						</div>
						<h2 class="text-3xl md:text-5xl font-black text-black-primary mb-6 leading-tight">
							Hablemos de tu próximo <span class="text-gold-accent">proyecto</span>
						</h2>
						<p class="text-lg text-slate-technical mb-10">
							¿Listo para dar el siguiente paso? Nuestro equipo de ingenieros y especialistas está preparado para asesorarte y encontrar la mejor solución en paneles SIP para ti.
						</p>

						<div class="space-y-6">
							<div class="flex items-center">
								<div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-gold-accent shadow-sm">
									<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
								</div>
								<div class="ml-4">
									<p class="text-sm text-gray-500 font-medium">Llámanos</p>
									<p class="text-lg font-bold text-black-primary">+56 9 1234 5678</p>
								</div>
							</div>
							<div class="flex items-center">
								<div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-gold-accent shadow-sm">
									<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
								</div>
								<div class="ml-4">
									<p class="text-sm text-gray-500 font-medium">Escríbenos</p>
									<p class="text-lg font-bold text-black-primary">contacto@vertys.cl</p>
								</div>
							</div>
							<div class="flex items-center">
								<div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-gold-accent shadow-sm">
									<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								</div>
								<div class="ml-4">
									<p class="text-sm text-gray-500 font-medium">Visítanos</p>
									<p class="text-lg font-bold text-black-primary">Av. Los Ángeles, Santiago</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Formulario de Contacto -->
					<div class="w-full lg:w-7/12 bg-white rounded-3xl shadow-xl p-8 md:p-12 border border-gray-100">
						<form class="space-y-6" onsubmit="event.preventDefault(); alert('Mensaje enviado exitosamente');">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								<div>
									<label class="block text-sm font-medium text-gray-700 mb-2">Nombre completo</label>
									<input type="text" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-gold-accent focus:border-gold-accent outline-none transition-all" placeholder="Juan Pérez" required />
								</div>
								<div>
									<label class="block text-sm font-medium text-gray-700 mb-2">Teléfono</label>
									<input type="tel" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-gold-accent focus:border-gold-accent outline-none transition-all" placeholder="+56 9 0000 0000" required />
								</div>
							</div>
							<div>
								<label class="block text-sm font-medium text-gray-700 mb-2">Correo electrónico</label>
								<input type="email" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-gold-accent focus:border-gold-accent outline-none transition-all" placeholder="juan@correo.com" required />
							</div>
							<div>
								<label class="block text-sm font-medium text-gray-700 mb-2">¿En qué te podemos ayudar?</label>
								<textarea rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-gold-accent focus:border-gold-accent outline-none transition-all resize-none" placeholder="Cuéntanos sobre tu proyecto o consulta..." required></textarea>
							</div>
							<button type="submit" class="w-full bg-black-primary hover:bg-gray-900 text-white font-bold py-4 px-8 rounded-xl transition-colors text-lg">
								Enviar mensaje
							</button>
						</form>
					</div>
					
				</div>
			</div>
		</section>
		
	</main>
	
	<Footer />
</Layout>
