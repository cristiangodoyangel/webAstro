---
import heroBg from '../img/hero.webp';
---

<section class="relative bg-black-primary pt-24 pb-32  flex items-center min-h-[80vh]">
  <!-- Background Pattern or Image Overlay -->
  <img src={heroBg.src} alt="" class="absolute inset-0 w-full h-full object-cover opacity-20 mix-blend-overlay" />
  <div class="absolute inset-0 bg-gradient-to-r from-black-primary/95 to-black-primary/80"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center">
    <div class="w-full md:w-1/2 text-white z-10 md:pr-10">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight mb-6 leading-tight">
        Líderes en Soluciones SIP <br/>
        <span class="text-gold-accent font-semibold text-xl md:text-xl">Edificación moderna, ágil y ecológica</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-xl font-light"> 
        Sistemas de paneles estructurales en todo Chile para proyectos de alto desempeño. Explora nuestras opciones de viviendas, espacios de trabajo y módulos con máxima protección térmica.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#modelos" class="bg-gold-accent hover:bg-yellow-600 text-white font-bold py-4 px-6  text-center transition-all duration-300 shadow-lg hover:shadow-yellow-500/30">
          Ver viviendas pre-diseñadas
        </a>
        <a href="#servicios" class="bg-transparent border-2 border-white hover:bg-white hover:text-black-primary text-white font-bold py-4 px-8  text-center transition-all duration-300">
          Cotizar proyecto a medida
        </a>
      </div>
    </div>
    
    <div class="w-full md:w-1/2 mt-12 md:mt-0 z-10 hidden md:block">
      <!-- Decorative Element or Image -->
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-gold-accent to-yellow-400 rounded-2xl blur opacity-30 animate-pulse"></div>
        <img src={heroBg.src} alt="Casa Construida con Paneles SIP" class="relative rounded-2xl shadow-2xl border-4 border-white/10 object-cover h-[450px] w-full" />
      </div>
    </div>
  </div>
  
  <!-- Wave shape divider -->
  
</section>
