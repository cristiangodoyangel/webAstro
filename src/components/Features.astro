---
import AboutUs from '../img/about.webp';
---

<section id="servicios" class="py-20 bg-grey-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-black-primary mb-4">Construye de forma inteligente con nuestra tecnología</h2>
      <p class="text-lg text-slate-technical max-w-2xl mx-auto">
        Todo lo que necesitas para conceptualizar, organizar y materializar tu nueva edificación de manera remota.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Feature 1 -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-gray-100 rounded-xl flex items-center justify-center mb-6 text-black-primary">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-text-dark mb-2">Respaldo</h3>
        <p class="text-gold-accent font-bold text-2xl mb-2">+ 1700</p>
        <p class="text-slate-technical text-sm">obras entregadas a nivel nacional</p>
      </div>

      <!-- Feature 2 -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-gray-100 rounded-xl flex items-center justify-center mb-6 text-black-primary">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-text-dark mb-2">Garantía</h3>
        <p class="text-gold-accent font-bold text-2xl mb-2">94,1%</p>
        <p class="text-slate-technical text-sm">de recomendación por nuestros usuarios</p>
      </div>

      <!-- Feature 3 -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-gray-100 rounded-xl flex items-center justify-center mb-6 text-black-primary">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-text-dark mb-2">Eficiencia</h3>
        <p class="text-gold-accent font-bold text-2xl mb-2">60%</p>
        <p class="text-slate-technical text-sm">menos gasto en climatización anual</p>
      </div>

      <!-- Feature 4 -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-gray-100 rounded-xl flex items-center justify-center mb-6 text-black-primary">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-text-dark mb-2">Eco-amigable</h3>
        <p class="text-gold-accent font-bold text-xl mb-2">55–95 kg CO₂e / m²</p>
        <p class="text-slate-technical text-sm">Emisiones mínimas, montaje limpio</p>
      </div>
    </div>
    
    <div class="mt-16 text-center">
      <a href="#contacto" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-medium rounded-2 text-white bg-black-primary hover:bg-gray-900 md:text-lg transition-colors">
        Habla con nuestros especialistas
      </a>
    </div>
  </div>
</section>

<!-- About Us / Quiénes Somos Section -->
<section id="respaldo" class="py-24 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-16">
      
      <!-- Text Content -->
      <div class="w-full lg:w-1/2 lg:pr-8">
       
        <h2 class="text-3xl md:text-5xl font-black text-black-primary mb-6 leading-tight">
          Ingeniería y Arquitectura de <span class="text-gold-accent">Vanguardia</span>
        </h2>
        <p class="text-lg text-slate-technical mb-6 leading-relaxed">
          En <strong>VERTYS</strong>, no solo ensamblamos paneles; desarrollamos soluciones habitacionales basadas en la más alta precisión técnica. Nuestro equipo está conformado por ingenieros estructurales y arquitectos de primer nivel, dedicados a maximizar la eficiencia térmica, acústica y estructural de cada proyecto.
        </p>
        
        <ul class="space-y-5">
          <li class="flex items-start">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gold-accent flex items-center justify-center mt-1">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="ml-4 text-black-primary font-medium text-lg">Cálculo estructural avanzado y antisísmico</span>
          </li>
          <li class="flex items-start">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gold-accent flex items-center justify-center mt-1">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="ml-4 text-black-primary font-medium text-lg">Arquitectura enfocada en la nula pérdida calórica</span>
          </li>
          <li class="flex items-start">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gold-accent flex items-center justify-center mt-1">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="ml-4 text-black-primary font-medium text-lg">Asesoría técnica integral y supervisión de obra</span>
          </li>
        </ul>
      </div>

      <!-- Image Content -->
      <div class="w-full lg:w-1/2 relative group">
        <div class="absolute inset-0 bg-gold-accent translate-x-4 translate-y-4 rounded-3xl opacity-20 transition-transform group-hover:translate-x-6 group-hover:translate-y-6 duration-500"></div>
        <img src={AboutUs.src} alt="Ingenieros y Arquitectos trabajando en planos" class="relative rounded-3xl shadow-2xl border-8 border-white w-full object-cover h-[500px] z-10" />
        
        <!-- Floating Badge -->
       
      </div>

    </div>
  </div>
</section>
